# Desktop / runtime
AIBUTLER_PYTHON=python3
AIBUTLER_ENABLE_FULL_ACCESS=0
AIBUTLER_ENABLE_COMPUTER_USE=0
AIBUTLER_ENABLE_KEYBOARD_USE=0

# Bridge
AIBUTLER_BRIDGE_ALLOW_LAN=0
AIBUTLER_BRIDGE_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Mobile / Expo
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=

# Notes
# - Store ElevenLabs API keys through desktop onboarding / Keychain.
# - Do not commit real secrets to this file.
