# Homebrew dependencies for aiButler.me development
# Run: brew bundle

# Core system tools
brew "ffmpeg"          # video/audio conversion
brew "imagemagick"     # image format conversion
brew "cliclick"        # macOS mouse/keyboard automation
brew "pyinstaller"     # Python → binary sidecar
brew "python@3.12"     # Python runtime

# Node / frontend
brew "node"            # Node.js for Svelte + Expo
brew "pnpm"            # fast package manager (optional)

# Rust / Tauri
brew "rust"            # Rust toolchain for Tauri 2
# cargo install tauri-cli --version ^2

# Optional
brew "maccy"           # clipboard manager (used by secrets layer)
brew "yt-dlp"          # YouTube downloader
